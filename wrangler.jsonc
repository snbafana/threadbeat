{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "threadbeat-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "vars": {
    "PROJECT_NAME": "threadbeat"
  },
  "d1_databases": [
    {
      "binding": "CONTROL_DB",
      "database_name": "threadbeat-d1",
      "database_id": "788a664c-38de-4b74-b6b8-946b6f417ee0"
    }
  ]
}
