THREADBEAT_DB_URL=file:.threadbeat/threadbeat.db
THREADBEAT_HOST=127.0.0.1
THREADBEAT_PORT=8000

# Default is dry-run so the API/CLI can be developed without cloud calls.
THREADBEAT_MODAL_MODE=dry-run
THREADBEAT_MODAL_APP_NAME=threadbeat-sandboxes
THREADBEAT_MODAL_IMAGE=python:3.13-slim

# Hosted Git provider. Supported: code-storage, github.
THREADBEAT_GIT_PROVIDER=code-storage
THREADBEAT_GITHUB_OWNER=
THREADBEAT_GITHUB_TOKEN=

# Required when THREADBEAT_MODAL_MODE=live.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Code.Storage / Pierre SDK. Required for live Code.Storage repo creation.
CODE_STORAGE_NAME=
CODE_STORAGE_PRIVATE_KEY=
