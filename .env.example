DEEPSEEK_API_KEY=

# Local development defaults to SQLite/libSQL on disk.
# THREADBEAT_DB_URL=file:.threadbeat/threadbeat.db
# THREADBEAT_DB_AUTH_TOKEN=

# Hosted Turso/Railway deployments can use Stripe Projects-pulled vars.
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# Runtime tuning.
# THREADBEAT_REPO_ROOT=/app
# THREADBEAT_POLL_SECONDS=10
# THREADBEAT_MAX_DUE_PER_POLL=1
# THREADBEAT_RUN_TIMEOUT_SECONDS=300
# THREADBEAT_PI_DRY_RUN=1
# THREADBEAT_LOG_REQUESTS=1
