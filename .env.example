THREADBEAT_DB_URL=file:.threadbeat/threadbeat.db
THREADBEAT_HOST=127.0.0.1
THREADBEAT_PORT=8000

# Default is dry-run so the API/CLI can be developed without cloud calls.
THREADBEAT_MODAL_MODE=dry-run
THREADBEAT_MODAL_APP_NAME=threadbeat-sandboxes
THREADBEAT_MODAL_IMAGE=python:3.13-slim
# Optional newline-separated Dockerfile commands layered onto THREADBEAT_MODAL_IMAGE.
# Use this to install sandbox-agent runtime dependencies such as Pi.
THREADBEAT_MODAL_IMAGE_COMMANDS=
THREADBEAT_AGENT_PI_COMMAND=pi
THREADBEAT_AGENT_PI_PROVIDER=deepseek
THREADBEAT_AGENT_PI_MODEL=deepseek-v4-flash
THREADBEAT_AGENT_PI_API_KEY_ENV=DEEPSEEK_API_KEY

# Sandbox-agent Pi auth. Keep this separate from any server-side Pi runtime.
THREADBEAT_SANDBOX_ENV_ALLOWLIST=DEEPSEEK_API_KEY
DEEPSEEK_API_KEY=

# Hosted Git provider. GitHub is the only enabled backend for now.
THREADBEAT_GIT_PROVIDER=github
THREADBEAT_GITHUB_OWNER=
THREADBEAT_GITHUB_OWNER_TYPE=auto
THREADBEAT_GITHUB_TOKEN=

# Required when THREADBEAT_MODAL_MODE=live.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
