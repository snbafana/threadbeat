{
  "name": "threadbeat",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/config.test.ts && tsx scripts/preflight.test.ts && tsx scripts/git-planning.test.ts && tsx scripts/rate-limit.test.ts && tsx scripts/hosted-git.test.ts && tsx scripts/agent-template.test.ts && tsx scripts/agent-boot.test.ts && tsx scripts/modal-image.test.ts && tsx scripts/git-repository-bootstrap.test.ts && tsx scripts/bootstrap-smoke.ts && tsx scripts/detached-session-smoke.ts && tsx scripts/smoke.ts",
    "smoke:github": "tsx scripts/github-live-smoke.ts",
    "smoke:github-init-cli": "tsx scripts/github-agent-init-cli-live-smoke.ts",
    "smoke:modal": "tsx scripts/modal-live-smoke.ts",
    "smoke:modal-cli": "tsx scripts/modal-cli-live-smoke.ts",
    "smoke:modal-pi-image": "tsx scripts/modal-pi-image-live-smoke.ts",
    "smoke:modal-agent-real-pi-runtime": "tsx scripts/modal-agent-boot-live-smoke.ts --real-pi",
    "smoke:modal-agent-real-task": "tsx scripts/modal-agent-real-task-live-smoke.ts",
    "smoke:modal-agent-boot": "tsx scripts/modal-agent-boot-live-smoke.ts",
    "smoke:detached-session": "tsx scripts/detached-session-smoke.ts",
    "smoke:session-apply-resume": "tsx scripts/session-apply-resume-smoke.ts",
    "smoke:branch-recovery-executions": "tsx scripts/branch-recovery-executions-smoke.ts",
    "smoke:control-plane-advances": "tsx scripts/control-plane-advances-smoke.ts",
    "smoke:worker-records": "tsx scripts/worker-record-sanitization-smoke.ts",
    "smoke:multi-agent-dispatch": "tsx scripts/multi-agent-dispatch-smoke.ts",
    "smoke:control-plane-live": "tsx scripts/control-plane-live-smoke.ts",
    "smoke:control-plane-real-task": "tsx scripts/control-plane-live-smoke.ts --real-task",
    "cli": "tsx scripts/threadbeat-cli.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "modal": "^0.7.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
