{
  "name": "threadbeat",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/git-planning.test.ts && tsx scripts/code-storage.test.ts && tsx scripts/rate-limit.test.ts && tsx scripts/hosted-git.test.ts && tsx scripts/bootstrap-smoke.ts && tsx scripts/smoke.ts",
    "smoke:code-storage": "tsx scripts/code-storage-live-smoke.ts",
    "smoke:github": "tsx scripts/github-live-smoke.ts",
    "smoke:modal": "tsx scripts/modal-live-smoke.ts",
    "smoke:modal-cli": "tsx scripts/modal-cli-live-smoke.ts",
    "cli": "tsx scripts/threadbeat-cli.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@pierre/storage": "^1.4.4",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "modal": "^0.7.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
